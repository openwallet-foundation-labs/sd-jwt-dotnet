{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SdJwt.Net.Oid4Vci": "Information"
    }
  },
  "Oid4Vci": {
    "IssuerUrl": "https://localhost:5001",
    "CredentialEndpointPath": "/credential",
    "TokenEndpointPath": "/token",
    "DeferredCredentialEndpointPath": "/deferred-credential",
    "AccessTokenLifetimeSeconds": 300,
    "CNonceLifetimeSeconds": 300,
    "CacheMetadataSeconds": 300,
    "EnableRateLimiting": false,
    "EnableCorrelationId": true,
    "CorrelationIdHeaderName": "X-Correlation-ID",
    "TokenCleanupIntervalSeconds": 60
  },
  "AllowedHosts": "*"
}
